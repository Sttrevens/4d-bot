# ---- 飞书 ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# OAuth 回调地址（多租户模式在 tenants.json 里配，单租户模式填这里）
# 格式: http(s)://your-domain/oauth/callback  注意不要带端口号（如果走 Nginx 反代）
FEISHU_OAUTH_REDIRECT_URI=

# ---- Kimi (Moonshot) ----
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
# 自定义机器人聊天人设（可选，不填用默认值）
KIMI_CHAT_SYSTEM_PROMPT=你是四缔游戏（4D Games）的技术副总监，团队都叫你"四哥"。你负责团队的技术解决方案设计与主要执行，同时管理项目 Git 仓库。你了解团队所有项目的代码，大家可以向你提需求、问项目相关的任何技术问题。回答风格：专业但不端着，简洁直接，必要时给出代码示例。如果有人提出需求或bug，先确认理解无误再行动。

# ---- Gemini（可选，配置后支持原生视频/音频多模态）----
GEMINI_API_KEY=
# 国内服务器访问 Gemini API 的两种方式（二选一）：
#
# 方式一（推荐）：Cloudflare Worker 反向代理
# 部署 cloudflare-worker/gemini-proxy.js，然后填入 Worker URL：
GOOGLE_GEMINI_BASE_URL=
#
# 方式二：本地 HTTP/SOCKS5 代理（需要服务器上有梯子）
# 例如：http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
GEMINI_PROXY=

# ---- DuckDuckGo 搜索代理（国内服务器必填）----
# 部署 cloudflare-worker/ddg-search-proxy.js，然后填入 Worker URL：
DDG_SEARCH_PROXY_URL=
# 如果 Worker 配了 ACCESS_TOKEN，填在这里：
DDG_SEARCH_PROXY_TOKEN=

# ---- 语音转写 STT（可选，配置后支持语音消息）----
# 需要 OpenAI-compatible Whisper API（如 OpenAI、Groq 等）
STT_API_KEY=
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1

# ---- Anthropic (可选，当前默认用 Kimi 编码，不填也能跑) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- GitHub ----
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_LOCAL_REPO_PATH=/tmp/workspace

# ---- Railway 自我迭代（可选，配置后 bot 能查看自己的部署日志、自动修 bug）----
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=

# ---- 自我仓库（可选，默认与 GITHUB_REPO 相同）----
# 当 bot 服务的 GITHUB_REPO 是别的项目时，需要设置这两个变量指向 bot 自身的仓库，
# 这样自我迭代（auto_fix）才能修复 bot 框架代码，而不是业务仓库。
# 如果 GITHUB_REPO 就是 bot 自己的仓库，可以不填。
SELF_REPO_OWNER=
SELF_REPO_NAME=

# ---- 多租户（可选，不配则使用上面的环境变量作为单租户）----
# 配置后支持多团队接入，每个团队独立的飞书 app、GitHub 仓库、LLM 配置
# JSON 格式见 tenants.example.json
TENANTS_CONFIG_PATH=

# ---- 服务 ----
HOST=0.0.0.0
PORT=8000
DEBUG=false
